# Meal Planner Environment Variables
# Copy this file to .env.local and fill in the values

# Convex Configuration (get from `npx convex dev`)
# These will be populated automatically by the Convex CLI
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# OpenAI API Key (set via Convex Dashboard, not here)
# Go to https://dashboard.convex.dev > Settings > Environment Variables
# Add OPENAI_API_KEY with your key from https://platform.openai.com/api-keys

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex auth (Clerk JWT issuer / frontend API URL)
CLERK_JWT_ISSUER_DOMAIN=

# Upload CORS allowlist for Convex HTTP actions
# Set these in Convex Dashboard -> Settings -> Environment Variables.
# APP_URL and VITE_APP_URL are both accepted by backend CORS logic.
# CORS_ALLOWED_ORIGINS is optional comma-separated extra origins.
APP_URL=http://localhost:3006
VITE_APP_URL=http://localhost:3006
CORS_ALLOWED_ORIGINS=

# Set NODE_ENV=production in production Convex deployments so localhost is not allowed.
NODE_ENV=development
